---
import Layout from '../../layouts/Layout.astro';
import { ReserveButton } from '../../components/forms/ReserveButton';

export function getStaticPaths() {
  return [
    { params: { id: 'h1' } },
    { params: { id: 'h2' } },
    { params: { id: 'h3' } },
  ];
}

const { id } = Astro.params;

// Mocked data
const mockedHotels: Record<string, any> = {
  h1: {
    name: "Hotel Docta Central",
    description: "Ubicado en el corazón de la ciudad con acceso a los mejores centros comerciales y gastronómicos. Perfecto para viajes de negocios o turismo urbano. Nuestras instalaciones cuentan con los más altos estándares de calidad y confort.",
    score: 4.8,
    image: "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1200&q=80",
    price: 120,
    amenities: ["Wi-Fi de Alta Velocidad", "Desayuno Buffet", "Gimnasio 24hs", "Centro de Negocios"]
  },
  h2: {
    name: "Resort Vista Bella",
    description: "Un resort exclusivo con vistas panorámicas a las sierras. Cuenta con spa, tres piscinas y restaurantes de primera clase. Es el lugar perfecto para unas vacaciones inolvidables en pareja o en familia.",
    score: 4.5,
    image: "https://images.unsplash.com/photo-1582719508461-905c673771fd?auto=format&fit=crop&w=1200&q=80",
    price: 250,
    amenities: ["Spa & Wellness", "3 Piscinas", "Cancha de Tenis", "Restaurante Gourmet", "Estacionamiento Privado"]
  },
  h3: {
    name: "Posada El Descanso",
    description: "Un lugar tranquilo y acogedor, ideal para escapar del ruido de la ciudad y conectar con la naturaleza. Disfrute de nuestra atención personalizada y ambientes rústicos de gran encanto.",
    score: 4.2,
    image: "https://images.unsplash.com/photo-1542314831-c6a4d27ce66f?auto=format&fit=crop&w=1200&q=80",
    price: 80,
    amenities: ["Pet Friendly", "Jardín Amplio", "Asadores", "Wi-Fi"]
  }
};

const hotel = mockedHotels[id as string] || mockedHotels.h1;
---

<Layout title={hotel.name}>
  <div class="container" style="padding: 2rem 1rem;">
    <div style="background-color: var(--bg-secondary); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); margin-bottom: 2rem;">
      <img src={hotel.image} alt={hotel.name} style="width: 100%; height: 400px; object-fit: cover;" />
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
      <div>
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
          <h1 class="text-2xl font-bold">{hotel.name}</h1>
          <span style="background-color: var(--accent); color: white; padding: 0.5rem 1rem; border-radius: var(--radius-md); font-weight: bold; font-size: 1.125rem;">
            ★ {hotel.score}
          </span>
        </div>
        
        <p class="text-secondary mb-8" style="font-size: 1.125rem; line-height: 1.6;">{hotel.description}</p>
        
        <h2 class="text-xl font-bold mb-4">Comodidades (Amenities)</h2>
        <ul style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; list-style: none; padding: 0;">
          {hotel.amenities.map((amenity: string) => (
            <li style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-secondary);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--success)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              {amenity}
            </li>
          ))}
        </ul>
      </div>
      
      <div>
        <div style="position: sticky; top: 100px; background-color: var(--bg-secondary); padding: 2rem; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-md);">
          <div style="margin-bottom: 1.5rem; text-align: center;">
            <span style="font-size: 2.5rem; font-weight: bold;">${hotel.price}</span>
            <span class="text-secondary"> / noche</span>
          </div>
          
          <ReserveButton hotelId={id as string} price={hotel.price} client:load />
        </div>
      </div>
    </div>
  </div>
</Layout>
